{
  "expo": {
    "name": "fidelepro-mobile",
    "slug": "fidelepro-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fidelepromobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fidelepro.app"
    },
    "android": {
      "package": "com.fidelepro.app",
      "adaptiveIcon": {
        "backgroundColor": "#6637ee",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "updates": {
      "url": "https://u.expo.dev/f2f1be30-74ba-48ce-bbf3-840d0379f2af",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      "@sentry/react-native/expo",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#6637ee",
          "dark": {
            "backgroundColor": "#3d1fa8"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "FidèlePro utilise la caméra pour scanner les QR codes de vos clients."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/splash-icon.png",
          "color": "#6637ee",
          "sounds": []
        }
      ],
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f2f1be30-74ba-48ce-bbf3-840d0379f2af"
      },
      "APP_ENV": "development",
      "SENTRY_DSN": ""
    },
    "owner": "lcc6z"
  }
}
